# --- Google AI (obrigatorio) ---
# Chave da API Gemini: https://aistudio.google.com/apikey
GOOGLE_API_KEY=sua-chave-gemini

# --- DataJud / CNJ (obrigatorio) ---
# Solicite em: https://datajud-wiki.cnj.jus.br/
DATAJUD_API_KEY=sua-chave-datajud

# --- LLM (opcional, padrao: gemini-2.0-flash) ---
# LLM_MODEL_NAME=gemini-2.0-flash

# --- Email (opcional - sem isso roda em modo simulacao) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu@gmail.com
# SMTP_PASSWORD=sua-senha-de-app
# EMAIL_DESTINATARIO=destinatario@email.com

# --- Slack (opcional) ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- Carteira de processos ---
# Caminho para o JSON com os processos (padrao: processos.json na raiz do projeto)
# PROCESSOS_PATH=processos.json

# --- Historico ---
# Caminho para o arquivo de historico de movimentacoes
# HISTORICO_PATH=historico_movimentacoes.json
